# AI 模型选择: openai / anthropic / deepseek
AI_PROVIDER=deepseek

# OpenAI API Key (从 https://platform.openai.com/api-keys 获取)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Claude API Key (可选，从 https://console.anthropic.com 获取)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# DeepSeek API Key (从 https://platform.deepseek.com/api_keys 获取)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI 模型
OPENAI_MODEL=gpt-4o-mini

# Claude 模型
CLAUDE_MODEL=claude-3-haiku-20240307

# DeepSeek 模型: deepseek-chat (V2) 或 deepseek-reasoner (R1)
DEEPSEEK_MODEL=deepseek-chat

# 应用配置
SECRET_KEY=change-this-to-a-random-secret-key
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
